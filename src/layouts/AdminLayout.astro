---
interface Props {
  title: string;
}
const { title } = Astro.props;
const nav = [
  { href: '/admin', label: 'Overview' },
  { href: '/admin/bookings', label: 'Bookings' },
  { href: '/admin/classes', label: 'Classes' },
  { href: '/admin/instructors', label: 'Instructors' },
];
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Studio Admin</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="stylesheet" href="/src/styles/global.css" />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body class="font-body bg-paper text-ink min-h-screen">
  <div class="flex min-h-screen">
    <aside class="w-56 border-r border-line p-6 shrink-0">
      <a href="/" class="font-display text-lg block mb-8">Core &amp; Balance</a>
      <nav class="space-y-1 text-sm">
        {nav.map((n) => (
          <a href={n.href} class="block px-3 py-2 rounded-md hover:bg-ink hover:text-paper transition-colors">{n.label}</a>
        ))}
      </nav>
      <form method="POST" action="/api/auth/logout" class="mt-10">
        <button type="submit" class="text-sm text-ink-muted hover:text-accent">Sign out</button>
      </form>
    </aside>
    <main class="flex-1 p-8 max-w-5xl">
      <slot />
    </main>
  </div>
</body>
</html>
