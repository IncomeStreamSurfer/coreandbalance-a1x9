---
import Base from '../../layouts/Base.astro';
---

<Base title="Booking Cancelled | Core & Balance Pilates" description="Your booking was not completed." noindex={true}>
  <section class="mx-auto max-w-xl px-6 py-24 text-center">
    <h1 class="font-display text-4xl leading-tight mb-4">No charge was made</h1>
    <p class="text-ink-muted leading-relaxed mb-8">
      You cancelled before payment completed, so your spot wasn't reserved. The session may still be available —
      head back to the schedule to pick a time that works.
    </p>
    <div class="flex justify-center gap-4">
      <a href="/schedule" class="rounded-full bg-ink px-6 py-3 text-sm font-medium text-paper hover:bg-accent transition-colors">Back to schedule</a>
      <a href="/contact" class="rounded-full border border-ink px-6 py-3 text-sm font-medium hover:border-accent hover:text-accent transition-colors">Contact us</a>
    </div>
  </section>
</Base>
