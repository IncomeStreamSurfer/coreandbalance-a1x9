---
import Base from '../layouts/Base.astro';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: (import.meta.env.PUBLIC_SITE_URL ?? '').replace(/\/$/, '') },
    { '@type': 'ListItem', position: 2, name: 'About', item: (import.meta.env.PUBLIC_SITE_URL ?? '').replace(/\/$/, '') + '/about' },
  ],
};
const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Core & Balance Pilates',
  url: (import.meta.env.PUBLIC_SITE_URL ?? '').replace(/\/$/, '') + '/about',
};
---

<Base
  title="About Us | Core & Balance Pilates Austin"
  description="Founded in 2019 on South Congress, Core & Balance Pilates is Austin's boutique studio for mat, reformer, and prenatal pilates."
  structuredData={[breadcrumb, aboutSchema]}
>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-8">
    <p class="text-xs uppercase tracking-[0.2em] text-accent font-medium mb-4">Our story</p>
    <h1 class="font-display text-4xl md:text-5xl leading-tight mb-8">Why we started this</h1>
    <div class="space-y-5 text-ink-muted leading-relaxed">
      <p>
        Core & Balance Pilates opened its doors on South Congress in 2019 because Austin didn't have a studio that
        felt like a neighborhood spot instead of a franchise. Our founder, Jamie Arnold, had spent a decade teaching
        at bigger studios where reformer classes ran 15+ people deep and instructors barely had time to say your name,
        let alone correct your form.
      </p>
      <p>
        We built the opposite. Reformer classes cap at six. Mat and barre classes cap at twelve. Every instructor on
        staff completed a comprehensive certification — not a weekend course — before teaching a single class here.
        And because we book everything online with real-time availability, you always know exactly how many spots
        are left before you show up.
      </p>
      <p>
        Today we run five class formats — mat, reformer, prenatal, barre fusion, and private sessions — taught by four
        instructors who between them hold certifications in sports rehab, dance, and pre/postnatal movement. Whether
        you're brand new to pilates or rebuilding strength after an injury or a pregnancy, we build the class around
        you, not the other way around.
      </p>
    </div>
  </section>

  <section class="border-t border-line mt-16">
    <div class="mx-auto max-w-6xl px-6 py-16 grid md:grid-cols-3 gap-8 text-center">
      <div>
        <p class="font-display text-4xl text-accent mb-2">2019</p>
        <p class="text-sm text-ink-muted">Opened on South Congress</p>
      </div>
      <div>
        <p class="font-display text-4xl text-accent mb-2">4</p>
        <p class="text-sm text-ink-muted">Certified instructors on staff</p>
      </div>
      <div>
        <p class="font-display text-4xl text-accent mb-2">6</p>
        <p class="text-sm text-ink-muted">Max reformer class size</p>
      </div>
    </div>
  </section>

  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 text-center">
      <h2 class="font-display text-3xl mb-4">Come see the studio</h2>
      <p class="text-ink-muted mb-8">Meet the instructors or book your first class — new members are always welcome.</p>
      <div class="flex justify-center gap-4">
        <a href="/instructors" class="rounded-full border border-ink px-6 py-3 text-sm font-medium hover:border-accent hover:text-accent transition-colors">Meet the team</a>
        <a href="/book" class="rounded-full bg-ink px-6 py-3 text-sm font-medium text-paper hover:bg-accent transition-colors">Book a class</a>
      </div>
    </div>
  </section>
</Base>
