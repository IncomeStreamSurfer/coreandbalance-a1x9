---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../../lib/requireAdmin';
import { ssrClient } from '../../../lib/supabase';

const forbidden = await requireAdmin(Astro);
if (forbidden) return forbidden;

const sb = ssrClient(Astro.cookies);
const { id } = Astro.params;
const { data: instr } = await sb!.from('instructors').select('*').eq('id', id).single();
if (!instr) return new Response('Not found', { status: 404 });
---
<AdminLayout title={`Edit ${instr.name}`}>
  <a href="/admin/instructors" class="text-sm text-ink-muted hover:text-accent">&larr; Back to instructors</a>
  <h1 class="font-display text-3xl mt-4 mb-8">Edit {instr.name}</h1>
  <form method="POST" action={`/api/admin/instructors/${instr.id}`} class="space-y-4 max-w-2xl">
    <label class="block"><span class="text-sm font-medium">Name</span>
      <input type="text" name="name" value={instr.name} required class="w-full mt-1 px-3 py-2 border border-line rounded" />
    </label>
    <label class="block"><span class="text-sm font-medium">Role</span>
      <input type="text" name="role" value={instr.role} class="w-full mt-1 px-3 py-2 border border-line rounded" />
    </label>
    <label class="block"><span class="text-sm font-medium">Bio</span>
      <textarea name="bio" rows="6" class="w-full mt-1 px-3 py-2 border border-line rounded">{instr.bio}</textarea>
    </label>
    <label class="flex items-center gap-2">
      <input type="checkbox" name="published" checked={!!instr.published_at} />
      <span class="text-sm">Published</span>
    </label>
    <div class="flex gap-3">
      <button type="submit" class="px-4 py-2 bg-ink text-paper rounded hover:bg-accent transition-colors">Save</button>
      <a href="/admin/instructors" class="px-4 py-2 border border-line rounded">Cancel</a>
    </div>
  </form>
</AdminLayout>
